{
  "name": "the-agents",
  "displayName": "The Agents",
  "description": "Watch AI agents work in a single-property visualization",
  "version": "1.0.0",
  "author": "zero.liquid88@gmail.com",
  "license": "MIT",
  "publisher": "local",
  "icon": "media-static/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/IronLain88/The-Agents-VSCode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentVillage.openViewer",
        "title": "Open The Agents"
      },
      {
        "command": "agentVillage.refresh",
        "title": "Refresh The Agents",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentVillage.refresh",
          "when": "view == agentVillage.sidebarView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-village",
          "title": "The Agents",
          "icon": "media-static/village-icon.svg"
        }
      ]
    },
    "views": {
      "agent-village": [
        {
          "type": "webview",
          "id": "agentVillage.sidebarView",
          "name": "The Agents"
        }
      ]
    },
    "configuration": {
      "title": "The Agents",
      "properties": {
        "agentVillage.hubUrl": {
          "type": "string",
          "default": "ws://localhost:4242",
          "description": "WebSocket URL of your The Agents hub server (e.g. ws://localhost:4242 or wss://your-server.com)"
        },
        "agentVillage.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for your hub server (enables clearing agents and editing tasks)"
        }
      }
    }
  },
  "scripts": {
    "bundle": "node scripts/bundle-media.js",
    "build": "npm run bundle && tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "npm run build && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
